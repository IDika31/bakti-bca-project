# ─── Frontend Environment (Next.js) ──────────────────────────────────
# Copy to .env.local for local dev. In Vercel, set per environment
# (Production / Preview / Development) via Project Settings → Environment Variables.
# NEXT_PUBLIC_* values are baked in at build time, so they MUST match the
# environment being built. See docs/DEVELOPMENT.md.

# Backend API base URL. Trailing slash optional — code prepends it to /api paths.
# Local: http://localhost:3001
# Vercel Production: https://[PROD_DOMAIN]  (same domain as frontend via rewrites)
# Vercel Preview: leave empty on Vercel — rewrites route /api to the backend service,
#                 so the frontend calls same-origin /api and needs no base URL.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Public app URL (for social/og/absolute links). Optional.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase (Realtime only — anon key is safe to expose)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
