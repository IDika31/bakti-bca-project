# ─── Backend Environment ─────────────────────────────────────────────
# Copy to .env for local dev. In Vercel, set the same keys per environment
# (Production / Preview / Development) via Project Settings → Environment Variables.
# Use a SEPARATE Supabase project for Preview/Development so production data
# stays safe. See docs/DEVELOPMENT.md for the full setup.

# ── Database (Supabase) ──
# Pooled connection (pgbouncer) — used by the app at runtime.
DATABASE_URL="postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — used by Prisma migrate / db push.
DIRECT_URL="postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Supabase (Storage) ──
SUPABASE_URL="https://[PROJECT].supabase.co"
# Service role key (server-only, never expose to frontend). SUPABASE_SECRET_KEY is accepted as a fallback.
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"
SUPABASE_STORAGE_BUCKET="restaurant-assets"

# ── JWT Auth (admin) ──
JWT_SECRET="[GENERATE: openssl rand -base64 32]"
JWT_EXPIRES_IN="24h"

# ── App / CORS ──
# Public URL of THIS backend. Local: http://localhost:3001.
# Vercel Production: https://[PROD_DOMAIN]. Vercel Preview: per-environment.
APP_URL="http://localhost:3001"
# Comma-separated list of allowed frontend origins for CORS.
FRONTEND_URL="http://localhost:3000"
PORT=3001

# ── Default customer email domain ──
# Used to generate a placeholder email when the customer leaves email blank at
# checkout. Keep neutral (NOT your real domain) so emails never leak the brand.
DEFAULT_EMAIL_DOMAIN="noreply.local"
